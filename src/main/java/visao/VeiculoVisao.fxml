<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane dividerPositions="0.35" prefHeight="550.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.VeiculoControlador">
  <items>
    <AnchorPane minWidth="280.0">
         <children>
            <VBox spacing="12.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
               <children>
                  <Label text="Cadastro de Veículo" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                  
                  <Label text="Marca:" />
                  <TextField fx:id="txtMarca" promptText="Ex: Chevrolet" />
                  
                  <Label text="Modelo:" />
                  <TextField fx:id="txtModelo" promptText="Ex: Onix" />
                  
                  <Label text="Cor:" />
                  <TextField fx:id="txtCor" promptText="Ex: Preto" />
                  
                  <Label text="Ano:" />
                  <TextField fx:id="txtAno" promptText="Ex: 2023" />
                  
                  <Label text="Preço:" />
                  <TextField fx:id="txtPreco" promptText="Ex: 75000.00" />
                  
                  <Label text="Status:" />
                  <ComboBox fx:id="cbStatus" prefWidth="250.0" />
                  
                  <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 15 0 0 0;">
                     <children>
                        <Button mnemonicParsing="false" onAction="#acaoSalvar" text="Salvar" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />
                        <Button mnemonicParsing="false" onAction="#acaoExcluir" text="Excluir" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
                        <Button mnemonicParsing="false" onAction="#acaoLimpar" text="Limpar" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </AnchorPane>
      
    <AnchorPane>
         <children>
            <TableView fx:id="tabelaVeiculos" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
              <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colMarca" prefWidth="110.0" text="Marca" />
                  <TableColumn fx:id="colModelo" prefWidth="120.0" text="Modelo" />
                  <TableColumn fx:id="colCor" prefWidth="90.0" text="Cor" />
                  <TableColumn fx:id="colAno" prefWidth="70.0" text="Ano" />
                  <TableColumn fx:id="colPreco" prefWidth="100.0" text="Preço" />
                  <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
              </columns>
            </TableView>
         </children>
      </AnchorPane>
  </items>
</SplitPane>