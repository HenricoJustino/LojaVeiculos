<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane dividerPositions="0.38" prefHeight="550.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.VendaControlador">
  <items>
    <AnchorPane minWidth="300.0">
         <children>
            <VBox spacing="10.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
               <children>
                  <Label text="Registrar Venda" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                  
                  <Label text="Cliente:" />
                  <ComboBox fx:id="cbCliente" prefWidth="300.0" promptText="Selecione o Cliente..." />
                  
                  <Label text="Funcionário (Vendedor):" />
                  <ComboBox fx:id="cbFuncionario" prefWidth="300.0" promptText="Selecione o Vendedor..." />
                  
                  <Label text="Veículo:" />
                  <ComboBox fx:id="cbVeiculo" prefWidth="300.0" promptText="Selecione o Veículo..." />
                  
                  <Label text="Data da Venda:" />
                  <DatePicker fx:id="dpDataVenda" prefWidth="300.0" />
                  
                  <Label text="Forma de Pagamento:" />
                  <ComboBox fx:id="cbFormaPagamento" prefWidth="300.0" promptText="Forma de Pagamento..." />
                  
                  <Label text="Valor Final (R$):" />
                  <TextField fx:id="txtValorFinal" promptText="Ex: 85000.00" />
                  
                  <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 15 0 0 0;">
                     <children>
                        <Button mnemonicParsing="false" onAction="#acaoSalvar" text="Salvar Venda" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
                        <Button mnemonicParsing="false" onAction="#acaoExcluir" text="Excluir" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
                        <Button mnemonicParsing="false" onAction="#acaoLimpar" text="Limpar" style="-fx-cursor: hand;" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </AnchorPane>
      
    <AnchorPane>
         <children>
            <TableView fx:id="tabelaVendas" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
              <columns>
                <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                <TableColumn fx:id="colIdCliente" prefWidth="70.0" text="ID Clie." />
                  <TableColumn fx:id="colIdFuncionario" prefWidth="70.0" text="ID Func." />
                  <TableColumn fx:id="colIdVeiculo" prefWidth="70.0" text="ID Veíc." />
                  <TableColumn fx:id="colData" prefWidth="95.0" text="Data Venda" />
                  <TableColumn fx:id="colFormaPagamento" prefWidth="105.0" text="Forma Pagto." />
                  <TableColumn fx:id="colValorFinal" prefWidth="90.0" text="Valor Final" />
              </columns>
            </TableView>
         </children>
      </AnchorPane>
  </items>
</SplitPane>